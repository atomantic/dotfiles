.AppleDouble
.DS_Store
.LSOverride
._*
.git_template/hooks/disabled-pc
id_rsa
# desktop image backups
img/*.backup.jpg
node_modules
# personal swap gitconfigs / per-identity gitconfigs (e.g. .gitconfig-work)
homedir/.gitconfig_*
homedir/.gitconfig-*
# machine-local override files written by install.sh. These normally live at ~/
# (outside the repo); ignored here too in case they ever land in the repo tree.
homedir/.gitconfig.local
homedir/.gitignore.local
homedir/.zshrc.local
homedir/.vim/backup/*
!homedir/.vim/backup/.gitignore
homedir/.vim/temp/*
!homedir/.vim/temp/.gitignore
homedir/.vim/.netrwhist
homedir/.vim/bundle/*
!homedir/.vim/bundle/.gitignore
!homedir/.vim/bundle/Vundle.vim
configs/hosts.local
stevenblack-hosts/myhosts
stevenblack-hosts/whitelist
stevenblack-hosts/blacklist
